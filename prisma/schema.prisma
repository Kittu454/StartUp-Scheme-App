generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  role          String
  provider      String
  startupStage  String?
  businessType  String?
  region        String?
  applications  Application[]
  createdAt     DateTime      @default(now())
}

model Scheme {
  id              String   @id @default(cuid())
  name            String
  shortDescription String
  fullDescription  String
  benefits        Json
  deadline        String
  authority       String
  region          String
  businessType    String
  requiredStage   String
  requirements    Json
  documents       Json
  sourceType      String
  websiteUrl      String
  createdAt       DateTime @default(now())
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  schemeId  String
  status    String
  date      String?
  interested Boolean @default(false)
  createdAt DateTime @default(now())
}
